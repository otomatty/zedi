# Admin app (Vite) - optional override
# VITE_PORT=30001

# Proxy to local API (same as main app). No VITE_ prefix so client does not see it.
# ZEDI_API_PROXY_TARGET=http://localhost:3000

# Production: set in Cloudflare Pages
# VITE_API_BASE_URL=https://api.zedi-note.app

# Main app URL for "Sign in" link on login page (default: https://zedi-note.app)
# VITE_MAIN_APP_URL=https://zedi-note.app

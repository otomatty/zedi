# =============================================================================
# 本番ビルド・デプロイ用環境変数テンプレート
# コピー: cp .env.production.example .env.production  (または copy on Windows)
# 値を埋めてから bun run deploy:prod を実行してください。
# =============================================================================

# -----------------------------------------------------------------------------
# ビルド時に埋め込まれる変数 (VITE_*)
# -----------------------------------------------------------------------------

# Cognito（必須）
# Terraform: terraform output -raw cognito_hosted_ui_url の https:// を除いた値
VITE_COGNITO_DOMAIN=your-cognito-domain.auth.ap-northeast-1.amazoncognito.com
VITE_COGNITO_CLIENT_ID=your_cognito_client_id

# コールバック URL（本番ドメイン）
VITE_COGNITO_REDIRECT_URI=https://zedi-note.app/auth/callback
VITE_COGNITO_LOGOUT_REDIRECT_URI=https://zedi-note.app

# REST API（Lambda + API Gateway）
# 同一 URL を AI API（HTTP）・サムネイル API でも使用。Terraform: terraform output -raw api_invoke_url
VITE_ZEDI_API_BASE_URL=https://xxxxxxxxxx.execute-api.ap-northeast-1.amazonaws.com

# AI WebSocket（ストリーミング用・必須）Terraform: terraform output -raw ai_api_websocket_url
VITE_AI_WS_URL=wss://xxxxxxxxxx.execute-api.ap-northeast-1.amazonaws.com/production

# Realtime（Hocuspocus WebSocket）
# Terraform: terraform output -raw websocket_url
VITE_REALTIME_URL=wss://realtime.zedi-note.app

# LemonSqueezy（Pro プラン課金）
# VITE_LEMONSQUEEZY_STORE_ID=
# VITE_LEMONSQUEEZY_AI_MONTHLY_PRODUCT_ID=
# VITE_LEMONSQUEEZY_AI_YEARLY_PRODUCT_ID=
# VITE_LEMONSQUEEZY_PORTAL_URL=

# -----------------------------------------------------------------------------
# デプロイ用（scripts/deploy/deploy-to-aws.ts で参照）
# AWS CLI は別途 AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY で認証すること
# -----------------------------------------------------------------------------

# Terraform: terraform output -raw frontend_s3_bucket
PROD_FRONTEND_S3_BUCKET=zedi-prod-frontend-123456789012

# Terraform: terraform output -raw cloudfront_distribution_id
PROD_CLOUDFRONT_DISTRIBUTION_ID=EXXXXXXXXXXXXX

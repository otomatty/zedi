# Cognito (Google/GitHub OAuth)
# Domain: from Terraform output or e.g. zedi-dev-590183877893.auth.ap-northeast-1.amazoncognito.com
VITE_COGNITO_DOMAIN=YOUR_COGNITO_DOMAIN
VITE_COGNITO_CLIENT_ID=YOUR_COGNITO_CLIENT_ID
# Optional: defaults to current origin + /auth/callback and origin for logout
# VITE_COGNITO_REDIRECT_URI=http://localhost:30000/auth/callback
# VITE_COGNITO_LOGOUT_REDIRECT_URI=http://localhost:30000

# REST API base URL (Zedi API, AI HTTP, Thumbnail API — single URL for all)
# AWS: terraform output -raw api_invoke_url
VITE_ZEDI_API_BASE_URL=YOUR_API_BASE_URL
# AI streaming WebSocket (wss://...). AWS: terraform output -raw ai_api_websocket_url
VITE_AI_WS_URL=YOUR_AI_WS_URL

# Polar (Pro plan billing)
# Product IDs: Polar dashboard > Products > "..." > Copy Product ID
VITE_POLAR_PRO_MONTHLY_PRODUCT_ID=YOUR_POLAR_MONTHLY_PRODUCT_ID
VITE_POLAR_PRO_YEARLY_PRODUCT_ID=YOUR_POLAR_YEARLY_PRODUCT_ID

# Realtime Collaboration (Hocuspocus)
# Development: ws://localhost:1234 or AWS ALB (see docs/work-logs/20260131/aws-connection-summary.md)
# Get URL: terraform -chdir=terraform output -raw websocket_url
# Example (dev ALB): ws://zedi-dev-alb-1515915657.ap-northeast-1.elb.amazonaws.com
# Production: wss://realtime.zedi-note.app
VITE_REALTIME_URL=YOUR_HOCUSPOCUS_WEBSOCKET_URL

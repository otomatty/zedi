# API Base URL (Better Auth + REST API)
VITE_API_BASE_URL=http://localhost:3000

# Realtime Collaboration (Hocuspocus WebSocket)
# Development: ws://localhost:1234
# Production: wss://realtime.zedi-note.app
VITE_REALTIME_URL=ws://localhost:1234

# Polar (Pro plan billing)
VITE_POLAR_PRO_MONTHLY_PRODUCT_ID=YOUR_POLAR_MONTHLY_PRODUCT_ID
VITE_POLAR_PRO_YEARLY_PRODUCT_ID=YOUR_POLAR_YEARLY_PRODUCT_ID

# Polar server-side (subscription management API: /api/subscription/change-plan)
POLAR_ACCESS_TOKEN=YOUR_POLAR_ACCESS_TOKEN
POLAR_PRO_MONTHLY_PRODUCT_ID=YOUR_POLAR_MONTHLY_PRODUCT_ID
POLAR_PRO_YEARLY_PRODUCT_ID=YOUR_POLAR_YEARLY_PRODUCT_ID

# OpenRouter (optional, for AI model sync: fetches pricing to set cost units per model)
# Get a key at https://openrouter.ai/keys — if unset, all models use default cost units.
# OPENROUTER_API_KEY=

# API server (production): set CORS_ORIGIN so CSRF origin check is active (see server middleware/csrfOrigin).
# Comma-separated allowed origins, e.g. https://zedi-note.app,https://admin.zedi-note.app
# CORS_ORIGIN=

# Docker Compose (docker-compose.dev.yml)
# Override defaults for local dev; required in shared/production. Do not commit real secrets.
# POSTGRES_USER=zedi
# POSTGRES_DB=zedi
# POSTGRES_PASSWORD=your-secure-password
# BETTER_AUTH_SECRET=your-secret-at-least-32-chars
# BETTER_AUTH_URL=http://localhost:3000
# CORS_ORIGIN=http://localhost:5173,http://localhost:30001

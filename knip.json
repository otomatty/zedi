{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "paths": {
    "@/*": ["./src/*"]
  },
  "vitest": true,
  "playwright": true,
  "workspaces": {
    ".": {
      "entry": ["src/main.tsx", "scripts/**/*.ts", "e2e/**/*.ts", "e2e/**/*.tsx"],
      "project": ["src/**/*.{ts,tsx}", "scripts/**/*.ts", "e2e/**/*.{ts,tsx}"]
    },
    "admin": {
      "entry": ["src/main.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/ui": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "server/api": {
      "entry": ["src/index.ts", "scripts/**/*.ts"],
      "project": ["src/**/*.ts", "scripts/**/*.ts"]
    },
    "server/hocuspocus": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreDependencies": ["tailwindcss-animate"]
}

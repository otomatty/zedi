# 本番 Terraform 用シークレット（IdP 必須）
# 使い方:
#   1. コピー: cp prod.secret.env.example prod.secret.env  (Git にコミットしない)
#   2. 下記に実際の値を記入
#   3. apply 前に読み込む:
#      Bash:    set -a && source environments/prod.secret.env && set +a
#      PowerShell: Get-Content environments/prod.secret.env | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2].Trim(), 'Process') } }
#   4. terraform apply -var-file=environments/prod.tfvars -auto-approve
#
# 本番で Google/GitHub サインインが有効になるには、以下が空でない必要があります。

# Google OAuth（GCP の「認証情報」で取得。Cognito 用リダイレクト URI を登録済みのクライアントのシークレット）
TF_VAR_google_oauth_client_secret=

# GitHub OAuth（GitHub Developer Settings で作成した OAuth App の Client Secret）
TF_VAR_github_oauth_client_secret=

# 任意: Thumbnail API（Google Custom Search）
# TF_VAR_thumbnail_google_custom_search_api_key=
# TF_VAR_thumbnail_google_custom_search_engine_id=

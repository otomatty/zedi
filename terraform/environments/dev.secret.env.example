# Terraform 用シークレット環境変数（IdP・Thumbnail API 等）
# 使い方:
#   1. このファイルをコピーして dev.secret.env を作成する
#      cp dev.secret.env.example dev.secret.env
#   2. dev.secret.env に実際のシークレットを記入する（このファイルは .gitignore で除外される）
#   3. terraform plan/apply の前に読み込む
#      Bash: source terraform/environments/dev.secret.env
#      PowerShell: Get-Content terraform/environments/dev.secret.env | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'Process') } }
#
# 変数名は Terraform が認識する TF_VAR_ プレフィックス付きで記載すること。

# IdP (Cognito)
TF_VAR_google_oauth_client_secret=
TF_VAR_github_oauth_client_secret=

# Thumbnail API (Google Custom Search) — 空のままならシークレットは作成され、後から AWS Console で設定可能
TF_VAR_thumbnail_google_custom_search_api_key=
TF_VAR_thumbnail_google_custom_search_engine_id=
